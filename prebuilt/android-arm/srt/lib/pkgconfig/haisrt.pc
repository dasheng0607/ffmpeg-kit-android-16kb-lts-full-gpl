prefix=/Users/vineshchauhan/Downloads/FFMPEG-KIT/ffmpeg-kit-16KB/prebuilt/android-arm/srt
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: srt
Description: SRT library set
Version: 1.5.4
Libs: -L${libdir} -lsrt   
Libs.private:  -lc -lm -ldl -llog -lc++_shared -latomic -lm -lc++ -lm -l:libunwind.a -ldl -lc -l:libunwind.a -ldl
Cflags: -I${includedir} -I${includedir}/srt
Requires.private: openssl libcrypto
